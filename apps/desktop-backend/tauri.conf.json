{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenMonkey",
  "version": "2.0.0",
  "identifier": "com.openmonkey.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "F:\\OpenMonkey-Trae\\dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenMonkey",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "OpenMonkey",
    "copyright": "Copyright © 2025 OpenMonkey",
    "category": "DeveloperTool",
    "shortDescription": "Universal AI Agent with Self-Evolution",
    "longDescription": "OpenMonkey is a local AI agent with zero dependencies, self-evolving capabilities, and a universal skill adapter.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {}
}
